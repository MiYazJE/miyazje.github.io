---
import { getCollection } from 'astro:content';
import GithubIcon from './Icons/GithubIcon.astro';
import ExternalIcon from './Icons/ExternalIcon.astro';

const projects = await getCollection('projects');
const data = [...projects.map((project) => project.data)].sort(
  (a, b) => a.sortOrder - b.sortOrder
);

const formatTag = (tag: string) => {
  const names: Record<string, string> = {
    javascript: 'JavaScript',
    react: 'React',
    'express.js': 'Express.js',
    'socket.io': 'Socket.IO',
    'passport.js': 'Passport.js',
    'mongo db': 'MongoDB',
    supabase: 'Supabase',
    'styled-components': 'Styled Components',
  };
  return names[tag] ?? tag;
};
---

<section class="section site-shell" id="projects" aria-labelledby="projects-title">
  <div class="section-heading reveal">
    <div>
      <p class="eyebrow">Selected work</p>
      <h2 class="section-title" id="projects-title">Products built around real people.</h2>
    </div>
    <p class="section-intro">
      A selection of end-to-end products spanning civic response, shared digital experiences and real-time multiplayer systems.
    </p>
  </div>

  <div class="project-list">
    {data.map((item, index) => {
      const { title, description, img, tags, urls } = item;
      const projectNumber = String(index + 1).padStart(2, '0');

      return (
        <article class="project-card reveal">
          <div class="project-visual">
            <div class="project-window">
              <div class="browser-bar">
                <span class="browser-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span>{title.toLowerCase().replaceAll(' ', '-')}.app</span>
              </div>
              <img src={img} alt={`${title} project interface`} loading="lazy" width="720" height="440" />
            </div>
          </div>

          <div class="project-body">
            <div class="project-index">
              <span>Project / {projectNumber}</span>
              <span>{index === 0 ? 'Featured' : 'Case study'}</span>
            </div>
            <h3>{title}</h3>
            <p>{description}</p>

            <ul class="tags" aria-label={`${title} technologies`}>
              {tags.map((tag) => <li>{formatTag(tag)}</li>)}
            </ul>

            <div class="project-links">
              {urls.website && (
                <a href={urls.website} target="_blank" rel="noreferrer">
                  <ExternalIcon /> <span>Visit product</span>
                </a>
              )}
              {urls.github && (
                <a href={urls.github} target="_blank" rel="noreferrer">
                  <GithubIcon /> <span>View source</span>
                </a>
              )}
            </div>
          </div>
        </article>
      );
    })}
  </div>
</section>

<style>
  .project-list {
    display: grid;
    width: min(100%, 67.5rem);
    gap: 1.25rem;
    margin-inline: auto;
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(20rem, 0.92fr);
    min-height: 26rem;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    background: var(--surface);
    box-shadow: 0 14px 50px color-mix(in srgb, var(--ink) 5%, transparent);
  }

  .project-card:nth-child(even) .project-visual {
    order: 2;
  }

  .project-visual {
    display: grid;
    min-width: 0;
    padding: clamp(1.2rem, 3vw, 2.5rem);
    place-items: center;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--accent-soft) 75%, var(--surface-subtle)), var(--surface-subtle));
  }

  .project-card:nth-child(2) .project-visual {
    background: linear-gradient(135deg, var(--signal-soft), var(--surface-subtle));
  }

  .project-card:nth-child(3) .project-visual {
    background: linear-gradient(135deg, color-mix(in srgb, #f2b84b 18%, var(--surface-subtle)), var(--surface-subtle));
  }

  .project-window {
    width: min(100%, 39rem);
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, var(--line));
    border-radius: 0.9rem;
    background: var(--surface);
    box-shadow: 0 30px 55px color-mix(in srgb, var(--ink) 16%, transparent);
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 500ms ease;
  }

  .project-card:hover .project-window {
    box-shadow: 0 38px 70px color-mix(in srgb, var(--ink) 22%, transparent);
    transform: translateY(-7px) rotate(-0.5deg);
  }

  .project-card:nth-child(even):hover .project-window {
    transform: translateY(-7px) rotate(0.5deg);
  }

  .browser-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 2.3rem;
    padding: 0 0.8rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.52rem;
  }

  .browser-dots {
    display: flex;
    gap: 0.28rem;
  }

  .browser-dots i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--line);
  }

  .project-window img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: top;
  }

  .project-body {
    display: flex;
    min-width: 0;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 3vw, 3rem);
  }

  .project-index {
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-index span:last-child {
    color: var(--muted);
  }

  h3 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(2rem, 3.4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .project-body > p {
    display: -webkit-box;
    margin: 1.4rem 0 0;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.75;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.28rem 0.55rem;
    border: 1px solid var(--line);
    border-radius: 0.4rem;
    background: var(--surface-subtle);
    color: var(--ink-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
  }

  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 2rem;
  }

  .project-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .project-links a:hover {
    color: var(--accent);
  }

  .project-links :global(svg) {
    width: 1rem;
    height: 1rem;
    stroke: currentColor;
  }

  @media (max-width: 900px) {
    .project-card {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .project-card:nth-child(even) .project-visual {
      order: initial;
    }

    .project-body {
      padding: 2rem;
    }

    .project-body > p {
      -webkit-line-clamp: initial;
    }
  }

  @media (max-width: 540px) {
    .project-card {
      border-radius: 1.1rem;
    }

    .project-visual {
      padding: 1.1rem;
    }

    .project-body {
      padding: 1.5rem;
    }

    .project-index {
      margin-bottom: 1.25rem;
    }
  }
</style>
