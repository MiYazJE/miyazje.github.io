---
import GithubIcon from './Icons/GithubIcon.astro';
import LinkedinIcon from './Icons/LinkedinIcon.astro';
---

<section class="hero site-shell" aria-labelledby="hero-title">
  <div class="hero-copy">
    <div class="identity-row">
      <img src="/images/me.jfif" alt="Rubén Saiz" width="72" height="72" />
      <div>
        <p class="eyebrow">Full-stack developer</p>
        <p class="location">Valencia, Spain <span aria-hidden="true">·</span> Building for the web</p>
      </div>
    </div>

    <h1 id="hero-title">
      I build digital products<br />
      from interface to infrastructure.
    </h1>

    <p class="hero-intro">
      I turn complex requirements into clear, reliable web applications. My work connects thoughtful React interfaces with scalable Node.js services, cloud infrastructure and clean engineering practices.
    </p>

    <div class="hero-actions">
      <a class="button button-primary" href="#projects">View selected work <span class="arrow" aria-hidden="true">↓</span></a>
      <a class="icon-link" href="https://github.com/MiYazJE" target="_blank" rel="noreferrer" aria-label="Rubén on GitHub">
        <GithubIcon />
      </a>
      <a class="icon-link" href="https://www.linkedin.com/in/rubensaizs/" target="_blank" rel="noreferrer" aria-label="Rubén on LinkedIn">
        <LinkedinIcon />
      </a>
    </div>

    <ul class="capabilities" aria-label="Core capabilities">
      <li><span>01</span> Product interfaces</li>
      <li><span>02</span> APIs & services</li>
      <li><span>03</span> Cloud delivery</li>
    </ul>
  </div>

  <div class="system-card reveal" aria-label="Full-stack system diagram">
    <div class="system-toolbar">
      <div class="window-controls" aria-hidden="true"><i></i><i></i><i></i></div>
      <span>product-system.graph</span>
      <span class="status"><i></i> healthy</span>
    </div>

    <div class="system-canvas">
      <div class="system-label">Request lifecycle</div>
      <div class="flow" aria-hidden="true">
        <div class="node node-ui">
          <small>interface</small>
          <strong>React UI</strong>
          <span>user experience</span>
        </div>
        <div class="connector connector-one"><i></i></div>
        <div class="node node-api">
          <small>gateway</small>
          <strong>Node API</strong>
          <span>business logic</span>
        </div>
        <div class="connector connector-two"><i></i></div>
        <div class="node node-data">
          <small>persistence</small>
          <strong>Data layer</strong>
          <span>reliable state</span>
        </div>
      </div>
      <div class="service-note"><span>↳</span> events routed to cloud services</div>
      <div class="stack-readout">
        <span>TypeScript</span><span>React</span><span>Node.js</span><span>AWS</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(26rem, 0.98fr);
    gap: clamp(3rem, 7vw, 7rem);
    align-items: center;
    min-height: 100svh;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  .hero-copy {
    min-width: 0;
  }

  .identity-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.2rem;
  }

  .identity-row img {
    width: 4.5rem;
    height: 4.5rem;
    border: 4px solid var(--surface);
    border-radius: 1.25rem 1.25rem 1.25rem 0.35rem;
    object-fit: cover;
    box-shadow: 0 0 0 1px var(--line), 0 12px 30px color-mix(in srgb, var(--ink) 10%, transparent);
  }

  .identity-row .eyebrow {
    margin-bottom: 0.45rem;
  }

  .location {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
  }

  h1 {
    max-width: 13ch;
    margin: 0;
    color: var(--ink);
    font-size: clamp(3rem, 4.4vw, 4.65rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 0.96;
    overflow-wrap: break-word;
  }

  .hero-intro {
    max-width: 42rem;
    margin: 2rem 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-top: 2rem;
  }

  .icon-link {
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    background: var(--surface);
    color: var(--ink);
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .icon-link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .icon-link :global(svg) {
    width: 1.2rem;
    height: 1.2rem;
    stroke: currentColor;
  }

  .capabilities {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    margin: 2.6rem 0 0;
    padding: 1.25rem 0 0;
    border-top: 1px solid var(--line);
    list-style: none;
  }

  .capabilities li {
    color: var(--ink-soft);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .capabilities span {
    margin-right: 0.35rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 400;
  }

  .system-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 1.4rem;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  :global(.dark) .system-card {
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.42), 0 0 0 1px rgba(137, 148, 255, 0.06);
  }

  .system-card::before {
    position: absolute;
    z-index: -1;
    top: -2rem;
    right: -2rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: var(--accent-soft);
    filter: blur(30px);
    content: '';
  }

  .system-toolbar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 3.2rem;
    padding: 0 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.65rem;
  }

  .window-controls {
    display: flex;
    gap: 0.35rem;
  }

  .window-controls i {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--line);
  }

  .status {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 0.4rem;
    color: var(--signal);
  }

  .status i {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 4px var(--signal-soft);
  }

  .system-canvas {
    position: relative;
    min-height: 33rem;
    padding: 1.5rem;
    background-image: radial-gradient(var(--line) 0.8px, transparent 0.8px);
    background-size: 18px 18px;
  }

  .system-label {
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .flow {
    position: relative;
    display: grid;
    max-width: 21rem;
    gap: 3rem;
    margin: 2.2rem auto 0;
  }

  .node {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 5.6rem;
    align-content: center;
    padding: 1rem 1.25rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: var(--surface);
    box-shadow: 0 12px 35px color-mix(in srgb, var(--ink) 8%, transparent);
  }

  .node small {
    margin-bottom: 0.25rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
    text-transform: uppercase;
  }

  .node strong {
    color: var(--ink);
    font-size: 0.95rem;
  }

  .node span {
    color: var(--muted);
    font-size: 0.7rem;
  }

  .node-api {
    margin-left: 2.8rem;
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    background: color-mix(in srgb, var(--accent-soft) 55%, var(--surface));
  }

  .node-data {
    margin-right: 1.5rem;
  }

  .connector {
    position: absolute;
    z-index: 1;
    left: 50%;
    width: 1px;
    height: 3.5rem;
    overflow: visible;
    background: var(--line);
  }

  .connector-one {
    top: 5.2rem;
    transform: rotate(-12deg);
  }

  .connector-two {
    top: 13.8rem;
    transform: rotate(14deg);
  }

  .connector i {
    position: absolute;
    top: 0;
    left: -3px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 5px var(--accent-soft);
    animation: packet 2.4s ease-in-out infinite;
  }

  .connector-two i {
    animation-delay: 1.2s;
  }

  .service-note {
    width: fit-content;
    margin: 1.8rem 0 0 auto;
    padding: 0.45rem 0.75rem;
    border: 1px solid color-mix(in srgb, var(--signal) 35%, var(--line));
    border-radius: 2rem;
    background: var(--signal-soft);
    color: var(--signal);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.58rem;
  }

  .stack-readout {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 2rem;
  }

  .stack-readout span {
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--line);
    border-radius: 0.35rem;
    background: var(--surface);
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.55rem;
  }

  @keyframes packet {
    0%, 10% { opacity: 0; transform: translateY(0); }
    30% { opacity: 1; }
    80% { opacity: 1; }
    100% { opacity: 0; transform: translateY(3.4rem); }
  }

  @media (max-width: 980px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 9rem;
    }

    .hero-copy,
    h1 {
      width: 100%;
      max-width: 50rem;
    }

    .system-card {
      width: min(100%, 42rem);
      margin-left: auto;
    }
  }

  @media (max-width: 540px) {
    .hero {
      gap: 4rem;
      padding-top: 7rem;
      padding-bottom: 0;
    }

    .identity-row img {
      width: 3.8rem;
      height: 3.8rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.8rem, 14vw, 4rem);
    }

    .system-canvas {
      min-height: 31rem;
      padding: 1rem;
    }

    .system-toolbar > span:nth-child(2) {
      display: none;
    }

    .system-toolbar {
      grid-template-columns: 1fr 1fr;
    }

    .flow {
      max-width: calc(100% - 1.2rem);
    }

    .node-api {
      margin-left: 1.5rem;
    }

    .capabilities {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
