---
import ThemeSwitchButton from './ThemeSwitchButton.astro';
---

<header class="site-header">
  <nav class="site-shell nav" aria-label="Primary navigation">
    <a class="brand" href="#top" aria-label="Rubén Saiz, home">
      <span class="brand-mark" aria-hidden="true">RS</span>
      <span class="brand-copy">
        <strong>Rubén Saiz</strong>
        <small>Full-stack developer</small>
      </span>
    </a>

    <div class="nav-links">
      <a href="#projects">Work</a>
      <a href="#experience">Experience</a>
    </div>

    <div class="nav-actions">
      <ThemeSwitchButton />
      <a class="cv-link" href="/CV-es.pdf" download>
        <span>Download CV</span>
        <svg class="cv-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
          <path d="M14 3v5h5M12 11v6m0 0-2.5-2.5M12 17l2.5-2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 30;
    top: 0;
    right: 0;
    left: 0;
    border-bottom: 1px solid transparent;
    background: var(--header);
    backdrop-filter: blur(18px) saturate(140%);
    transition: border-color 180ms ease, box-shadow 180ms ease;
  }

  .site-header.is-scrolled {
    border-color: var(--line);
    box-shadow: 0 10px 35px color-mix(in srgb, var(--ink) 6%, transparent);
  }

  .nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 5rem;
    gap: 2rem;
  }

  .brand {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
  }

  .brand-mark {
    display: grid;
    width: 2.35rem;
    height: 2.35rem;
    place-items: center;
    border-radius: 0.7rem 0.7rem 0.7rem 0.2rem;
    background: var(--ink);
    color: var(--canvas);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .brand-copy {
    display: grid;
    line-height: 1.1;
  }

  .brand-copy strong {
    font-size: 0.88rem;
  }

  .brand-copy small {
    margin-top: 0.28rem;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
  }

  .nav-links,
  .nav-actions {
    display: flex;
    align-items: center;
  }

  .nav-links {
    gap: 2rem;
    color: var(--muted);
    font-size: 0.84rem;
    font-weight: 700;
  }

  .nav-links a {
    position: relative;
  }

  .nav-links a::after {
    position: absolute;
    right: 0;
    bottom: -0.45rem;
    left: 0;
    height: 2px;
    background: var(--accent);
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 180ms ease;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-actions {
    justify-content: flex-end;
    gap: 0.65rem;
  }

  .cv-link {
    display: inline-flex;
    min-height: 2.6rem;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.85rem;
    border-radius: 0.7rem;
    background: var(--ink);
    color: var(--canvas);
    font-size: 0.76rem;
    font-weight: 800;
    transition: transform 180ms ease;
  }

  .cv-link:hover {
    transform: translateY(-2px);
  }

  .cv-icon {
    flex: none;
  }

  @media (max-width: 760px) {
    .nav {
      grid-template-columns: 1fr auto;
      min-height: 4.4rem;
      gap: 0.75rem;
    }

    .nav-links,
    .brand-copy {
      display: none;
    }

    .cv-link span {
      display: none;
    }

    .cv-link {
      width: 2.6rem;
      justify-content: center;
      padding: 0;
      font-size: 1rem;
    }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const updateHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 16);
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
